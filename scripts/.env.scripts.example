# Configuration des scripts utilitaires InternLog
# Copier en .env.scripts et remplir avec les vraies valeurs.
# Le fichier .env.scripts est gitignored via le pattern .env*

# === Supabase (backup-supabase.py) ===
# URL du projet Supabase cloud (pas le local)
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Clé service_role — à récupérer dans Dashboard Supabase → Project Settings → API
# ATTENTION : donne un accès admin TOTAL à la base (bypasse les RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# === OVH SFTP (backup-supabase.py) ===
# Hôte SFTP OVH (cluster visible dans Manager OVH → Hébergement → FTP-SSH)
OVH_HOST=ssh.clusterXXX.hosting.ovh.net
# Utilisateur SFTP OVH
OVH_USER=xxxxxx
# Mot de passe SFTP OVH — DOIT être différent de tout autre credential
OVH_PASS=xxxxxx
# Dossier distant (optionnel, défaut = /home/$OVH_USER/backups/internlog)
OVH_REMOTE_DIR=/home/xxxxxx/backups/internlog
